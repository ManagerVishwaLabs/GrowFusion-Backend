PORT=8000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/glowfusion
PASSWORD_PEPPER=sample_password_pepper_value_change_in_production
JWT_SECRET=sample_jwt_secret_value_change_in_production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:3000
LOG_LEVEL=info
INSTAGRAM_CLIENT_ID=your_instagram_app_id
INSTAGRAM_CLIENT_SECRET=your_instagram_app_secret
INSTAGRAM_REDIRECT_URI=http://localhost:8000/api/v1/auth/instagram/callback/
INSTAGRAM_FORCE_RE_AUTH=true
